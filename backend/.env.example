# PostgreSQL
# 方式一：分别配置（本地开发常用）
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=shotmaster
DB_SSLMODE=disable

# 方式二：PaaS 上常见的完整连接串（Render / Railway / Fly.io 等）
# 若设置 DATABASE_URL，则优先使用它，上面的 DB_* 字段会被忽略
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# JWT
JWT_SECRET=shotmaster-secret
JWT_EXPIRE_HOURS=24

# 默认管理员账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 服务端口
# PaaS 通常注入 PORT，程序会优先读取 PORT，其次 SERVER_PORT，默认 8080
SERVER_PORT=8080
